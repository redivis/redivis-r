# Makevars for redivis
#
# FUSE libraries are loaded at runtime via dlopen — no FUSE headers,
# dev packages, or compile-time detection needed.
# Only libcurl is required at compile time (for HTTP range requests).

PKG_CFLAGS =
PKG_LIBS =

# --- Detect libcurl ---
CURL_CFLAGS := $(shell pkg-config --cflags libcurl 2>/dev/null)
CURL_LIBS   := $(shell pkg-config --libs   libcurl 2>/dev/null)

ifneq ($(CURL_LIBS),)
  PKG_CFLAGS += $(CURL_CFLAGS)
  PKG_LIBS   += $(CURL_LIBS)
else
  CURL_CFLAGS := $(shell curl-config --cflags 2>/dev/null)
  CURL_LIBS   := $(shell curl-config --libs   2>/dev/null)
  ifneq ($(CURL_LIBS),)
    PKG_CFLAGS += $(CURL_CFLAGS)
    PKG_LIBS   += $(CURL_LIBS)
  else
    $(error libcurl not found. Please install libcurl development files (e.g., libcurl4-openssl-dev on Debian/Ubuntu, libcurl-devel on Fedora/RHEL, or brew install curl on macOS).)
  endif
endif

PKG_LIBS += -lpthread -ldl
